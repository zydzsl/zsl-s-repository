<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="zsl.web.mapper.emp_exprmapper">
    <insert id="insertbatch">
<!--        循环批量添加数据-->
        insert into emp_expr(emp_id,begin_date,end_date,job,company) values
        <foreach collection="emp_exprs" item="emp_expr" separator=",">
            (#{emp_expr.empId},#{emp_expr.beginDate},#{emp_expr.endDate},#{emp_expr.job},#{emp_expr.company})
        </foreach>
    </insert>

    <delete id="delete">
    delete from emp_expr where emp_id in
    <foreach item="id" collection="ids" separator="," open="(" close=")">
        #{id}
    </foreach>
    </delete>
</mapper>